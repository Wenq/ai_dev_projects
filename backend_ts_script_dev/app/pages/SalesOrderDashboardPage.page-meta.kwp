<?xml version="1.0" encoding="UTF-8"?>

<Page>
    <!-- KWC表单ID，保障name在应用下唯一 -->
    <name>kdtest_SalesOrderDashboardPage</name>
    <!-- KWC表单显示名称 -->
    <masterLabel>费用申请单仪表盘</masterLabel>
    <!-- 表单模板类型，目前仅支持oneregion -->
    <template>oneregion</template>
    <!-- 使用脚手架部署时会自动填充isv -->
    <isv>kdtest</isv>
    <!-- 使用脚手架创建时会自动填充app -->
    <app>kdtest_kwc_wenq</app>
    <!-- 正整数的版本号，每次升级手动调整加1 -->
    <version>3</version>
    <regions>
        <region>
            <name>region1</name>
            <controls>
                <!-- 销售订单仪表盘组件 -->
                <control>
                    <type>SalesOrderDashboard</type>
                    <name>salesOrderDashboardInstance</name>
                </control>
            </controls>
        </region>
    </regions>
</Page>
